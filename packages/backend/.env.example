# SatoshiStacks Configuration
# Copy this to .env and customize for your environment

# Server port
PORT=3001

# Node environment: development or production
NODE_ENV=production

# CORS origin — your domain for production
# For multiple origins: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# Admin dashboard token — CHANGE THIS!
ADMIN_TOKEN=your-secret-admin-token-here

# Nostr server identity (nsec) — used for publishing badges and live activities
# Generate one: node -e "const {generateSecretKey}=require('nostr-tools/pure');const {nsecEncode}=require('nostr-tools/nip19');console.log(nsecEncode(generateSecretKey()))"
NOSTR_SERVER_NSEC=your-server-nsec-here
